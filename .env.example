# Supabase project settings (Project Settings > API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: USDA FoodData Central API key, used as a fallback product lookup
# when Open Food Facts has no record for a barcode. Falls back to the shared
# DEMO_KEY (30 req/hour, 50/day) if unset. Free, instant signup:
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=
